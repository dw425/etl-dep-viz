<?xml version="1.0" encoding="UTF-8"?>
<template encoding-version="1.3">
  <name>ETL_Customer_Pipeline</name>
  <snippet>
    <processGroups>
      <id>pg-001</id>
      <name>Customer_Ingest</name>
      <processors>
        <id>proc-001</id>
        <name>QueryCustomerDB</name>
        <type>org.apache.nifi.processors.standard.QueryDatabaseTable</type>
        <config>
          <properties>
            <entry><key>Table Name</key><value>CUSTOMER_SOURCE</value></entry>
            <entry><key>Database Connection URL</key><value>jdbc:oracle:thin:@host:1521/DB</value></entry>
          </properties>
        </config>
        <position><x>100</x><y>100</y></position>
      </processors>
      <processors>
        <id>proc-002</id>
        <name>TransformCustomer</name>
        <type>org.apache.nifi.processors.standard.JoltTransformJSON</type>
        <config>
          <properties>
            <entry><key>Jolt Specification</key><value>[{"operation":"shift"}]</value></entry>
          </properties>
        </config>
        <position><x>300</x><y>100</y></position>
      </processors>
      <processors>
        <id>proc-003</id>
        <name>WriteCustomerDW</name>
        <type>org.apache.nifi.processors.standard.PutDatabaseRecord</type>
        <config>
          <properties>
            <entry><key>Table Name</key><value>CUSTOMER_DW</value></entry>
            <entry><key>put-db-record-table-name</key><value>CUSTOMER_DW</value></entry>
          </properties>
        </config>
        <position><x>500</x><y>100</y></position>
      </processors>
      <processors>
        <id>proc-004</id>
        <name>GetOrderFeed</name>
        <type>org.apache.nifi.processors.standard.GetFile</type>
        <config>
          <properties>
            <entry><key>Directory</key><value>/data/orders</value></entry>
          </properties>
        </config>
        <position><x>100</x><y>300</y></position>
      </processors>
      <processors>
        <id>proc-005</id>
        <name>ParseOrderCSV</name>
        <type>org.apache.nifi.processors.standard.ConvertRecord</type>
        <config>
          <properties/>
        </config>
        <position><x>300</x><y>300</y></position>
      </processors>
      <processors>
        <id>proc-006</id>
        <name>EnrichOrder</name>
        <type>org.apache.nifi.processors.standard.LookupRecord</type>
        <config>
          <properties/>
        </config>
        <position><x>500</x><y>300</y></position>
      </processors>
      <processors>
        <id>proc-007</id>
        <name>WriteOrderKafka</name>
        <type>org.apache.nifi.processors.kafka.PublishKafka_2_6</type>
        <config>
          <properties>
            <entry><key>topic</key><value>orders-enriched</value></entry>
          </properties>
        </config>
        <position><x>700</x><y>300</y></position>
      </processors>
      <processors>
        <id>proc-008</id>
        <name>LogErrors</name>
        <type>org.apache.nifi.processors.standard.LogAttribute</type>
        <config>
          <properties/>
        </config>
        <position><x>500</x><y>500</y></position>
      </processors>
      <connections>
        <id>conn-001</id>
        <name/>
        <source><id>proc-001</id><name>QueryCustomerDB</name></source>
        <destination><id>proc-002</id><name>TransformCustomer</name></destination>
        <selectedRelationships>success</selectedRelationships>
      </connections>
      <connections>
        <id>conn-002</id>
        <name/>
        <source><id>proc-002</id><name>TransformCustomer</name></source>
        <destination><id>proc-003</id><name>WriteCustomerDW</name></destination>
        <selectedRelationships>success</selectedRelationships>
      </connections>
      <connections>
        <id>conn-003</id>
        <name/>
        <source><id>proc-004</id><name>GetOrderFeed</name></source>
        <destination><id>proc-005</id><name>ParseOrderCSV</name></destination>
        <selectedRelationships>success</selectedRelationships>
      </connections>
      <connections>
        <id>conn-004</id>
        <name/>
        <source><id>proc-005</id><name>ParseOrderCSV</name></source>
        <destination><id>proc-006</id><name>EnrichOrder</name></destination>
        <selectedRelationships>success</selectedRelationships>
      </connections>
      <connections>
        <id>conn-005</id>
        <name/>
        <source><id>proc-006</id><name>EnrichOrder</name></source>
        <destination><id>proc-007</id><name>WriteOrderKafka</name></destination>
        <selectedRelationships>success</selectedRelationships>
      </connections>
      <connections>
        <id>conn-006</id>
        <name/>
        <source><id>proc-002</id><name>TransformCustomer</name></source>
        <destination><id>proc-008</id><name>LogErrors</name></destination>
        <selectedRelationships>failure</selectedRelationships>
      </connections>
      <connections>
        <id>conn-007</id>
        <name/>
        <source><id>proc-006</id><name>EnrichOrder</name></source>
        <destination><id>proc-008</id><name>LogErrors</name></destination>
        <selectedRelationships>failure</selectedRelationships>
      </connections>
    </processGroups>
  </snippet>
</template>
