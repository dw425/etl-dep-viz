<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE POWERMART SYSTEM "powrmart.dtd">
<POWERMART>
  <REPOSITORY NAME="REPO_DEV">
    <FOLDER NAME="ETL_CUSTOMER" OWNER="admin">
      <!-- SOURCE definitions -->
      <SOURCE NAME="CUSTOMER_RAW" DATABASENAME="CUSTOMER_RAW" DBDTYPE="Oracle"/>
      <SOURCE NAME="ORDER_HEADER" DATABASENAME="ORDER_HEADER" DBDTYPE="Oracle"/>
      <SOURCE NAME="ORDER_LINE" DATABASENAME="ORDER_LINE" DBDTYPE="Oracle"/>
      <SOURCE NAME="PRODUCT_REF" DATABASENAME="PRODUCT_REF" DBDTYPE="Oracle"/>

      <!-- TARGET definitions -->
      <TARGET NAME="CUSTOMER_DIM" DATABASENAME="CUSTOMER_DIM" DBDTYPE="Oracle"/>
      <TARGET NAME="ORDER_FACT" DATABASENAME="ORDER_FACT" DBDTYPE="Oracle"/>
      <TARGET NAME="PRODUCT_DIM" DATABASENAME="PRODUCT_DIM" DBDTYPE="Oracle"/>

      <!-- TRANSFORMATION definitions (lookups) -->
      <TRANSFORMATION NAME="LKP_CUSTOMER_XREF" TYPE="Lookup Procedure">
        <TABLEATTRIBUTE NAME="Lookup table name" VALUE="CUSTOMER_XREF"/>
        <TRANSFORMFIELD NAME="CUST_ID" DATATYPE="string" PRECISION="50" EXPRESSION="CUST_ID" PORTTYPE="INPUT/OUTPUT"/>
        <TRANSFORMFIELD NAME="XREF_KEY" DATATYPE="string" PRECISION="100" EXPRESSION="XREF_KEY" PORTTYPE="OUTPUT"/>
      </TRANSFORMATION>
      <TRANSFORMATION NAME="LKP_PRODUCT_MASTER" TYPE="Lookup Procedure">
        <TABLEATTRIBUTE NAME="Lookup table name" VALUE="PRODUCT_MASTER"/>
        <TRANSFORMFIELD NAME="PROD_ID" DATATYPE="string" PRECISION="50" EXPRESSION="PROD_ID" PORTTYPE="INPUT/OUTPUT"/>
      </TRANSFORMATION>

      <!-- MAPPING 1: Load Customer Dimension -->
      <MAPPING NAME="m_LOAD_CUSTOMER_DIM">
        <INSTANCE NAME="SQ_CUSTOMER_RAW" TYPE="SOURCE" TRANSFORMATION_NAME="CUSTOMER_RAW" TRANSFORMATION_TYPE="Source Qualifier"/>
        <INSTANCE NAME="LKP_CUSTOMER_XREF" TYPE="TRANSFORMATION" TRANSFORMATION_NAME="LKP_CUSTOMER_XREF" TRANSFORMATION_TYPE="Lookup Procedure"/>
        <INSTANCE NAME="EXP_DERIVE_FIELDS" TYPE="TRANSFORMATION" TRANSFORMATION_NAME="EXP_DERIVE_FIELDS" TRANSFORMATION_TYPE="Expression"/>
        <INSTANCE NAME="TGT_CUSTOMER_DIM" TYPE="TARGET" TRANSFORMATION_NAME="CUSTOMER_DIM" TRANSFORMATION_TYPE="Target Definition"/>
        <CONNECTOR FROMINSTANCE="SQ_CUSTOMER_RAW" FROMFIELD="CUST_ID" TOINSTANCE="LKP_CUSTOMER_XREF" TOFIELD="CUST_ID" FROMINSTANCETYPE="Source Qualifier" TOINSTANCETYPE="Lookup Procedure"/>
        <CONNECTOR FROMINSTANCE="LKP_CUSTOMER_XREF" FROMFIELD="XREF_KEY" TOINSTANCE="EXP_DERIVE_FIELDS" TOFIELD="XREF_KEY" FROMINSTANCETYPE="Lookup Procedure" TOINSTANCETYPE="Expression"/>
        <CONNECTOR FROMINSTANCE="EXP_DERIVE_FIELDS" FROMFIELD="DERIVED_KEY" TOINSTANCE="TGT_CUSTOMER_DIM" TOFIELD="CUST_KEY" FROMINSTANCETYPE="Expression" TOINSTANCETYPE="Target Definition"/>
      </MAPPING>

      <!-- MAPPING 2: Load Order Fact -->
      <MAPPING NAME="m_LOAD_ORDER_FACT">
        <INSTANCE NAME="SQ_ORDER_HEADER" TYPE="SOURCE" TRANSFORMATION_NAME="ORDER_HEADER" TRANSFORMATION_TYPE="Source Qualifier"/>
        <INSTANCE NAME="SQ_ORDER_LINE" TYPE="SOURCE" TRANSFORMATION_NAME="ORDER_LINE" TRANSFORMATION_TYPE="Source Qualifier"/>
        <INSTANCE NAME="LKP_PRODUCT_MASTER" TYPE="TRANSFORMATION" TRANSFORMATION_NAME="LKP_PRODUCT_MASTER" TRANSFORMATION_TYPE="Lookup Procedure"/>
        <INSTANCE NAME="JNR_ORDER_LINE" TYPE="TRANSFORMATION" TRANSFORMATION_NAME="JNR_ORDER_LINE" TRANSFORMATION_TYPE="Joiner"/>
        <INSTANCE NAME="AGG_ORDER_TOTAL" TYPE="TRANSFORMATION" TRANSFORMATION_NAME="AGG_ORDER_TOTAL" TRANSFORMATION_TYPE="Aggregator"/>
        <INSTANCE NAME="TGT_ORDER_FACT" TYPE="TARGET" TRANSFORMATION_NAME="ORDER_FACT" TRANSFORMATION_TYPE="Target Definition"/>
        <CONNECTOR FROMINSTANCE="SQ_ORDER_HEADER" FROMFIELD="ORDER_ID" TOINSTANCE="JNR_ORDER_LINE" TOFIELD="ORDER_ID" FROMINSTANCETYPE="Source Qualifier" TOINSTANCETYPE="Joiner"/>
        <CONNECTOR FROMINSTANCE="SQ_ORDER_LINE" FROMFIELD="LINE_ID" TOINSTANCE="JNR_ORDER_LINE" TOFIELD="LINE_ID" FROMINSTANCETYPE="Source Qualifier" TOINSTANCETYPE="Joiner"/>
        <CONNECTOR FROMINSTANCE="JNR_ORDER_LINE" FROMFIELD="PROD_ID" TOINSTANCE="LKP_PRODUCT_MASTER" TOFIELD="PROD_ID" FROMINSTANCETYPE="Joiner" TOINSTANCETYPE="Lookup Procedure"/>
      </MAPPING>

      <!-- MAPPING 3: Load Product Dim (reads CUSTOMER_DIM — creates chain) -->
      <MAPPING NAME="m_LOAD_PRODUCT_DIM">
        <INSTANCE NAME="SQ_PRODUCT_REF" TYPE="SOURCE" TRANSFORMATION_NAME="PRODUCT_REF" TRANSFORMATION_TYPE="Source Qualifier"/>
        <INSTANCE NAME="SQ_CUSTOMER_DIM" TYPE="SOURCE" TRANSFORMATION_NAME="CUSTOMER_DIM" TRANSFORMATION_TYPE="Source Qualifier"/>
        <INSTANCE NAME="FIL_ACTIVE" TYPE="TRANSFORMATION" TRANSFORMATION_NAME="FIL_ACTIVE" TRANSFORMATION_TYPE="Filter"/>
        <INSTANCE NAME="TGT_PRODUCT_DIM" TYPE="TARGET" TRANSFORMATION_NAME="PRODUCT_DIM" TRANSFORMATION_TYPE="Target Definition"/>
      </MAPPING>

      <!-- SESSIONS -->
      <SESSION NAME="s_LOAD_CUSTOMER_DIM" MAPPINGNAME="m_LOAD_CUSTOMER_DIM"/>
      <SESSION NAME="s_LOAD_ORDER_FACT" MAPPINGNAME="m_LOAD_ORDER_FACT"/>
      <SESSION NAME="s_LOAD_PRODUCT_DIM" MAPPINGNAME="m_LOAD_PRODUCT_DIM"/>

      <!-- WORKFLOW with execution links -->
      <WORKFLOW NAME="wf_CUSTOMER_ETL">
        <TASKINSTANCE TASKNAME="s_LOAD_CUSTOMER_DIM" TASKTYPE="Session" REFERENCETASKNAME="s_LOAD_CUSTOMER_DIM"/>
        <TASKINSTANCE TASKNAME="s_LOAD_ORDER_FACT" TASKTYPE="Session" REFERENCETASKNAME="s_LOAD_ORDER_FACT"/>
        <TASKINSTANCE TASKNAME="s_LOAD_PRODUCT_DIM" TASKTYPE="Session" REFERENCETASKNAME="s_LOAD_PRODUCT_DIM"/>
        <WORKFLOWLINK FROMTASK="Start" TOTASK="s_LOAD_CUSTOMER_DIM"/>
        <WORKFLOWLINK FROMTASK="s_LOAD_CUSTOMER_DIM" TOTASK="s_LOAD_ORDER_FACT"/>
        <WORKFLOWLINK FROMTASK="s_LOAD_CUSTOMER_DIM" TOTASK="s_LOAD_PRODUCT_DIM"/>
      </WORKFLOW>
    </FOLDER>

    <FOLDER NAME="ETL_STAGING" OWNER="admin">
      <SOURCE NAME="EXT_FEED_A" DATABASENAME="EXT_FEED_A" DBDTYPE="FlatFile"/>
      <SOURCE NAME="EXT_FEED_B" DATABASENAME="EXT_FEED_B" DBDTYPE="FlatFile"/>
      <TARGET NAME="STG_COMBINED" DATABASENAME="STG_COMBINED" DBDTYPE="Oracle"/>
      <TARGET NAME="CUSTOMER_DIM" DATABASENAME="CUSTOMER_DIM" DBDTYPE="Oracle"/>

      <!-- This session also writes to CUSTOMER_DIM → creates write conflict -->
      <MAPPING NAME="m_STG_LOAD">
        <INSTANCE NAME="SQ_FEED_A" TYPE="SOURCE" TRANSFORMATION_NAME="EXT_FEED_A" TRANSFORMATION_TYPE="Source Qualifier"/>
        <INSTANCE NAME="SQ_FEED_B" TYPE="SOURCE" TRANSFORMATION_NAME="EXT_FEED_B" TRANSFORMATION_TYPE="Source Qualifier"/>
        <INSTANCE NAME="RTR_SPLIT" TYPE="TRANSFORMATION" TRANSFORMATION_NAME="RTR_SPLIT" TRANSFORMATION_TYPE="Router"/>
        <INSTANCE NAME="TGT_STG" TYPE="TARGET" TRANSFORMATION_NAME="STG_COMBINED" TRANSFORMATION_TYPE="Target Definition"/>
      </MAPPING>
      <MAPPING NAME="m_CONFLICT_CUST">
        <INSTANCE NAME="SQ_STG" TYPE="SOURCE" TRANSFORMATION_NAME="STG_COMBINED" TRANSFORMATION_TYPE="Source Qualifier"/>
        <INSTANCE NAME="TGT_CUST" TYPE="TARGET" TRANSFORMATION_NAME="CUSTOMER_DIM" TRANSFORMATION_TYPE="Target Definition"/>
      </MAPPING>

      <SESSION NAME="s_STG_LOAD" MAPPINGNAME="m_STG_LOAD"/>
      <SESSION NAME="s_CONFLICT_CUST_LOAD" MAPPINGNAME="m_CONFLICT_CUST"/>

      <WORKFLOW NAME="wf_STAGING">
        <TASKINSTANCE TASKNAME="s_STG_LOAD" TASKTYPE="Session" REFERENCETASKNAME="s_STG_LOAD"/>
        <TASKINSTANCE TASKNAME="s_CONFLICT_CUST_LOAD" TASKTYPE="Session" REFERENCETASKNAME="s_CONFLICT_CUST_LOAD"/>
        <WORKFLOWLINK FROMTASK="Start" TOTASK="s_STG_LOAD"/>
        <WORKFLOWLINK FROMTASK="s_STG_LOAD" TOTASK="s_CONFLICT_CUST_LOAD"/>
      </WORKFLOW>
    </FOLDER>

    <FOLDER NAME="ETL_REPORTING" OWNER="admin">
      <SOURCE NAME="ORDER_FACT" DATABASENAME="ORDER_FACT" DBDTYPE="Oracle"/>
      <SOURCE NAME="PRODUCT_DIM" DATABASENAME="PRODUCT_DIM" DBDTYPE="Oracle"/>
      <TARGET NAME="RPT_SALES_SUMMARY" DATABASENAME="RPT_SALES_SUMMARY" DBDTYPE="Oracle"/>

      <!-- LKP reads CUSTOMER_DIM — creating a staleness edge -->
      <TRANSFORMATION NAME="LKP_CUST_NAME" TYPE="Lookup Procedure">
        <TABLEATTRIBUTE NAME="Lookup table name" VALUE="CUSTOMER_DIM"/>
      </TRANSFORMATION>

      <MAPPING NAME="m_RPT_SALES">
        <INSTANCE NAME="SQ_ORDER_FACT" TYPE="SOURCE" TRANSFORMATION_NAME="ORDER_FACT" TRANSFORMATION_TYPE="Source Qualifier"/>
        <INSTANCE NAME="SQ_PRODUCT_DIM" TYPE="SOURCE" TRANSFORMATION_NAME="PRODUCT_DIM" TRANSFORMATION_TYPE="Source Qualifier"/>
        <INSTANCE NAME="LKP_CUST_NAME" TYPE="TRANSFORMATION" TRANSFORMATION_NAME="LKP_CUST_NAME" TRANSFORMATION_TYPE="Lookup Procedure"/>
        <INSTANCE NAME="EXP_CALC" TYPE="TRANSFORMATION" TRANSFORMATION_NAME="EXP_CALC" TRANSFORMATION_TYPE="Expression"/>
        <INSTANCE NAME="SRT_BY_DATE" TYPE="TRANSFORMATION" TRANSFORMATION_NAME="SRT_BY_DATE" TRANSFORMATION_TYPE="Sorter"/>
        <INSTANCE NAME="TGT_RPT" TYPE="TARGET" TRANSFORMATION_NAME="RPT_SALES_SUMMARY" TRANSFORMATION_TYPE="Target Definition"/>
      </MAPPING>

      <SESSION NAME="s_RPT_SALES" MAPPINGNAME="m_RPT_SALES"/>

      <WORKFLOW NAME="wf_REPORTING">
        <TASKINSTANCE TASKNAME="s_RPT_SALES" TASKTYPE="Session" REFERENCETASKNAME="s_RPT_SALES"/>
        <WORKFLOWLINK FROMTASK="Start" TOTASK="s_RPT_SALES"/>
      </WORKFLOW>
    </FOLDER>
  </REPOSITORY>
</POWERMART>
